{
  "custom_allowed_domains": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "remoteUser": "vscode",
    "features": {
      "claude-code": {
        "allowedDomains": "example.org, example.net"
      }
    }
  },
  "oauth_token_via_remote_env": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "remoteUser": "vscode",
    "remoteEnv": {
      "CLAUDE_CODE_OAUTH_TOKEN": "test-oauth-token-value"
    },
    "features": {
      "claude-code": {}
    }
  },
  "pinned_version": {
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "remoteUser": "vscode",
    "features": {
      "claude-code": {
        "version": "2.1.218"
      }
    }
  }
}
